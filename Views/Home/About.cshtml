@{
    ViewData["Title"] = "About RentEase";
}

<div class="container py-5" style="max-width:800px;">
    <h1 class="fw-bold mb-2">About RentEase</h1>
    <p class="text-muted mb-4">Connecting tenants and landlords across India</p>

    <div class="detail-card mb-4">
        RentEase is a free rental platform that makes it easy to find apartments, houses, PG accommodations, co-living spaces, and sharing rooms anywhere in India. Whether you're a landlord looking to list your property or a tenant searching for the perfect home, RentEase has you covered.
        RentEase is proudly owned and operated by Rout IT Solutions.
    </div>

    <div class="row g-4">
        <div class="col-md-4 text-center">
            <div class="how-icon mx-auto"><i class="bi bi-house-heart"></i></div>
            <h5 class="fw-bold mt-2">Free Listings</h5>
            <p class="text-muted small">Post your property for free and reach thousands of potential tenants.</p>
        </div>
        <div class="col-md-4 text-center">
            <div class="how-icon mx-auto"><i class="bi bi-shield-check"></i></div>
            <h5 class="fw-bold mt-2">Verified Details</h5>
            <p class="text-muted small">Detailed property information including amenities, nearby places and more.</p>
        </div>
        <div class="col-md-4 text-center">
            <div class="how-icon mx-auto"><i class="bi bi-chat-dots"></i></div>
            <h5 class="fw-bold mt-2">Direct Chat</h5>
            <p class="text-muted small">Chat directly with landlords and share contact info securely.</p>
        </div>
    </div>
</div>
