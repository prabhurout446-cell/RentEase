@model RentEase.ViewModels.PropertyCreateViewModel
@{
    ViewData["Title"] = "Edit Listing";
}

<div class="container py-4" style="max-width:800px;">
    <h2 class="fw-bold mb-4"><i class="bi bi-pencil me-2"></i>Edit Listing</h2>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="form-card mb-3">
            <h5 class="form-card-title">Basic Info</h5>
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Title" class="form-label fw-semibold"></label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PropertyType" class="form-label fw-semibold"></label>
                    <select asp-for="PropertyType" class="form-select">
                        @foreach (var t in Enum.GetValues<RentEase.Models.PropertyType>())
                        { <option value="@((int)t)">@t</option> }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="ListingType" class="form-label fw-semibold"></label>
                    <select asp-for="ListingType" class="form-select">
                        <option value="0">Entire Place</option>
                        <option value="1">Sharing</option>
                        <option value="2">Co-Living / PG</option>
                    </select>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                </div>
            </div>
        </div>

        <div class="form-card mb-3">
            <h5 class="form-card-title">Location</h5>
            <div class="row g-3">
                <div class="col-12"><label asp-for="Address" class="form-label fw-semibold"></label><input asp-for="Address" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="City" class="form-label fw-semibold"></label><input asp-for="City" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="State" class="form-label fw-semibold"></label><input asp-for="State" class="form-control" /></div>
                <div class="col-md-4"><label asp-for="PinCode" class="form-label fw-semibold"></label><input asp-for="PinCode" class="form-control" /></div>
            </div>
        </div>

        <div class="form-card mb-3">
            <h5 class="form-card-title">Rent & Deposit</h5>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="RentAmount" class="form-label fw-semibold"></label>
                    <div class="input-group"><span class="input-group-text">₹</span><input asp-for="RentAmount" type="number" class="form-control" /></div>
                </div>
                <div class="col-md-4">
                    <label asp-for="DepositAmount" class="form-label fw-semibold"></label>
                    <div class="input-group"><span class="input-group-text">₹</span><input asp-for="DepositAmount" type="number" class="form-control" /></div>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input asp-for="IsNegotiable" class="form-check-input" type="checkbox" />
                        <label asp-for="IsNegotiable" class="form-check-label">Negotiable</label>
                    </div>
                </div>
            </div>
        </div>

        <div class="form-card mb-3">
            <h5 class="form-card-title">Availability</h5>
            <div class="col-md-4">
                <label asp-for="AvailableFrom" class="form-label fw-semibold"></label>
                <input asp-for="AvailableFrom" type="date" class="form-control" />
            </div>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary fw-semibold">
                <i class="bi bi-check2-circle me-2"></i>Save Changes
            </button>
            <a asp-action="MyListings" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
