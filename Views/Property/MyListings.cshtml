@model List<RentEase.Models.Property>
@{
    ViewData["Title"] = "My Listings";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0"><i class="bi bi-building me-2"></i>My Listings</h2>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Post New Property</a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-house-x fs-1 text-muted d-block mb-3"></i>
            <h5 class="text-muted">No listings yet</h5>
            <p class="text-muted">Start by posting your first property</p>
            <a asp-action="Create" class="btn btn-primary">Post a Property</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var p in Model)
            {
                var primaryImage = p.Images?.FirstOrDefault(i => i.IsPrimary) ?? p.Images?.FirstOrDefault();
                var imgSrc = primaryImage != null ? primaryImage.ImagePath : "/images/no-property.svg";

                <div class="col-md-6 col-lg-4">
                    <div class="my-listing-card @(!p.IsAvailable ? "listing-unavailable" : "")">
                        <div class="listing-img-wrap">
                            <img src="@imgSrc" alt="@p.Title" onerror="this.src='/images/no-property.svg'" class="listing-img" />
                            <span class="badge @(p.IsAvailable ? "bg-success" : "bg-danger") listing-status-badge">
                                @(p.IsAvailable ? "Active" : "Inactive")
                            </span>
                        </div>
                        <div class="p-3">
                            <h6 class="fw-bold mb-1">@p.Title</h6>
                            <p class="text-muted small mb-1"><i class="bi bi-geo-alt me-1"></i>@p.City, @p.State</p>
                            <p class="text-primary fw-semibold mb-2">₹@p.RentAmount.ToString("N0")/month</p>
                            <div class="d-flex gap-2 flex-wrap mb-3">
                                <span class="badge bg-light text-dark border">@p.PropertyType</span>
                                <span class="badge bg-light text-dark border">@p.ListingType</span>
                                <span class="badge bg-light text-dark border"><i class="bi bi-eye me-1"></i>@p.ViewCount views</span>
                            </div>
                            <div class="d-flex gap-2 flex-wrap">
                                <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye me-1"></i>View
                                </a>
                                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </a>
                                <form asp-action="ToggleAvailability" asp-route-id="@p.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm @(p.IsAvailable ? "btn-outline-secondary" : "btn-outline-success")">
                                        <i class="bi bi-toggle-@(p.IsAvailable ? "on" : "off") me-1"></i>
                                        @(p.IsAvailable ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                                <form asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Are you sure you want to delete this listing?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash me-1"></i>Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
