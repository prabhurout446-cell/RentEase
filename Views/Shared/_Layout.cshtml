<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RentEase</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-house-heart-fill me-2"></i>RentEase
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Property" asp-action="Index">
                            <i class="bi bi-search me-1"></i>Browse
                        </a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Property" asp-action="Create">
                                <i class="bi bi-plus-circle me-1"></i>Post Property
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Property" asp-action="MyListings">
                                <i class="bi bi-building me-1"></i>My Listings
                            </a>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link position-relative" asp-controller="Chat" asp-action="Inbox">
                                <i class="bi bi-chat-dots me-1"></i>Messages
                                <span class="badge bg-danger rounded-pill position-absolute top-0 start-100 translate-middle d-none" id="unreadBadge">0</span>
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name?.Split('@')[0]
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>Profile</a></li>
                                <li><a class="dropdown-item" asp-controller="Property" asp-action="MyListings"><i class="bi bi-list-ul me-2"></i>My Listings</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm ms-2" asp-controller="Account" asp-action="Register">Sign Up Free</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show m-0" role="alert">
            <div class="container">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show m-0" role="alert">
            <div class="container">
                <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <main>
        @RenderBody()
    </main>

    <footer class="footer mt-auto py-4">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="fw-bold"><i class="bi bi-house-heart-fill me-2"></i>RentEase</h5>
                    <p class="text-white small">Find your perfect home or list your property with ease. Connecting tenants and landlords across India.</p>
                </div>
                <div class="col-md-2">
                    <h6 class="fw-semibold">Quick Links</h6>
                    <ul class="list-unstyled small">
                        <li><a asp-controller="Property" asp-action="Index" class="footer-link">Browse Properties</a></li>
                        <li><a asp-controller="Property" asp-action="Create" class="footer-link">Post Property</a></li>
                        <li><a asp-controller="Home" asp-action="About" class="footer-link">About Us</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h6 class="fw-semibold">Property Types</h6>
                    <ul class="list-unstyled small">
                        <li><a href="/Property/Index?PropertyType=0" class="footer-link">Apartments</a></li>
                        <li><a href="/Property/Index?PropertyType=1" class="footer-link">Houses</a></li>
                        <li><a href="/Property/Index?ListingType=2" class="footer-link">Co-Living / PG</a></li>
                        <li><a href="/Property/Index?ListingType=1" class="footer-link">Sharing</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h6 class="fw-semibold text-white">Contact</h6>
                    <p class="text-white small"><i class="bi bi-envelope me-1"></i>prabhurout446@gmail.com</p>
                    <p class="text-white small"><i class="bi bi-telephone me-1"></i> +91 8926356522</p>
                </div>
            </div>
            <hr class="my-3" />
            <p class="text-center text-muted small mb-0">&copy; @DateTime.Now.Year RentEase. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
