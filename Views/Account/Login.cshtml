@model RentEase.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="container py-5" style="max-width:440px;">
    <div class="auth-card">
        <div class="text-center mb-4">
            <i class="bi bi-house-heart-fill fs-1 text-primary d-block mb-2"></i>
            <h3 class="fw-bold">Welcome Back</h3>
            <p class="text-muted">Sign in to your RentEase account</p>
        </div>

        <form asp-action="Login" method="post">
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="alert alert-danger" style="font-size:0.9em;"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold">Password</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label">Remember me</label>
            </div>
            <button type="submit" class="btn btn-primary w-100 fw-semibold py-2">Sign In</button>
        </form>

        <p class="text-center mt-3 text-muted">
            Don't have an account? <a asp-action="Register" class="text-primary fw-semibold">Register Free</a>
        </p>
    </div>
</div>
