@model RentEase.Models.ApplicationUser
@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-5" style="max-width:600px;">
    <div class="detail-card text-center py-4">
        <div class="profile-avatar mb-3">
            <i class="bi bi-person-circle fs-1"></i>
        </div>
        <h3 class="fw-bold mb-1">@Model.FullName</h3>
        <p class="text-muted mb-1"><i class="bi bi-envelope me-1"></i>@Model.Email</p>
        @if (!string.IsNullOrEmpty(Model.PhoneNumber))
        {
            <p class="text-muted mb-2"><i class="bi bi-telephone me-1"></i>@Model.PhoneNumber</p>
        }
        <small class="text-muted">Member since @Model.CreatedAt.ToString("MMMM yyyy")</small>
        <hr />
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Property" asp-action="MyListings" class="btn btn-primary">
                <i class="bi bi-building me-1"></i>My Listings
            </a>
            <a asp-controller="Chat" asp-action="Inbox" class="btn btn-outline-primary">
                <i class="bi bi-chat-dots me-1"></i>Messages
            </a>
        </div>
    </div>
</div>
